# Copy to .env.local (gitignored) and fill in.
#
# NEXT_PUBLIC_ vars get baked into the client JS bundle at `next build` time --
# that's why these live here and not in .dev.vars. Next.js reads this file
# automatically during `next build`/`next dev` (standard Next.js behavior,
# nothing OpenNext-specific). Never put a real secret behind NEXT_PUBLIC_ --
# anything prefixed this way ships to every visitor's browser.
#
# Server-only secrets (Stripe, Twilio, MiniMax, etc.) go in .dev.vars instead
# -- see .dev.vars.example for why the split exists.

# GA4 (plan §6).
NEXT_PUBLIC_GA4_MEASUREMENT_ID=

# Cloudflare Turnstile (plan §11) -- site key is public by design; the
# matching secret key goes in .dev.vars.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Stripe publishable key (plan §4) -- only needed if a client-side Stripe.js
# call is used; the primary flow (server-created Checkout Session, guest
# redirected to a URL) doesn't require it. Harmless to have ready either way.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
